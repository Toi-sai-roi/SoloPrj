# ==========================================
# Cyberpunk Chat Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
# Option 1: Full connection string (Railway/Render)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Option 2: Individual vars (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cyberpunk_chat
DB_USER=postgres
DB_PASSWORD=your_password

# JWT (Generate: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# File Upload
UPLOAD_MAX_SIZE=8388608